# ── Tecnimotos API — Variables de entorno ─────────────────────────────────────
# Copiar a .env y completar antes de ejecutar.
# NUNCA commitear .env — ver .gitignore.

# ── General ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
API_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000

# ── Base de datos (PostgreSQL + asyncpg) ──────────────────────────────────────
# Password estándar para desarrollo local: tecnimotos_dev
# Fuente de verdad: docker-compose.yml → POSTGRES_PASSWORD=tecnimotos_dev
# settings.py usa este mismo default → pytest sin DATABASE_URL encuentra la BD sin skip.
# Si no usas Docker local, ajusta host/port/password a tu instancia.
# Railway: obtener de Railway Dashboard → Variables → DATABASE_URL (no usar este valor).
DATABASE_URL=postgresql+asyncpg://tecnimotos:tecnimotos_dev@localhost:5432/tecnimotos
DATABASE_URL_SYNC=postgresql://tecnimotos:tecnimotos_dev@localhost:5432/tecnimotos

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PARAMS_DB=redis://localhost:6379/1
REDIS_NOTIFICATIONS_DB=redis://localhost:6379/2

# ── JWT RS256 (07 §2.1) ───────────────────────────────────────────────────────
# Generar par de claves:
#   mkdir -p keys
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Cifrado Fernet (datos personales — 03 §5.7) ───────────────────────────────
# Generar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Railway: cargar como variable de entorno — NUNCA en código fuente
FERNET_KEY=REPLACE_ME

# ── WhatsApp Business API ─────────────────────────────────────────────────────
WHATSAPP_API_TOKEN=REPLACE_ME
WHATSAPP_PHONE_NUMBER_ID=REPLACE_ME

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
SMS_PROVIDER=twilio
SMS_API_KEY=REPLACE_ME
SMS_ACCOUNT_SID=REPLACE_ME

# ── Cloudflare R2 — almacenamiento de imágenes (03 §3.5) ─────────────────────
# R2_ACCOUNT_ID: ID de cuenta Cloudflare (ej. abc123def456...).
# R2_ENDPOINT:   URL S3-compatible de R2, incluye account_id:
#                https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
#                El backend usa esta URL solo internamente para autenticar
#                con R2 — nunca se expone en respuestas HTTP al frontend.
# R2_BUCKET_NAME: nombre del bucket R2.
# R2_PUBLIC_URL: subdominio r2.dev del bucket (acceso público):
#                https://<token>.r2.dev
#                Esta URL sí aparece en las respuestas al frontend.
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY: token R2 con permisos
#   "Object Read & Write" sobre el bucket. Generar en
#   Cloudflare Dashboard → R2 → Manage R2 API Tokens.
# Railway: cargar todas las variables en el Dashboard — NUNCA en código fuente.
R2_ACCOUNT_ID=REPLACE_ME
R2_ENDPOINT=REPLACE_ME
R2_BUCKET_NAME=REPLACE_ME
R2_PUBLIC_URL=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME

# MFA por correo (ADR-011) — solo SUPERADMIN/ADMINISTRADOR reciben código real.
# RESEND_API_KEY: API key de Resend (https://resend.com/api-keys) — Railway no
#   ofrece SMTP propio, Resend evita gestionar TLS/25/587 a mano.
# MFA_EMAIL_FROM: remitente verificado en Resend, formato "Nombre <email>".
# Railway: cargar en el Dashboard — NUNCA en código fuente.
RESEND_API_KEY=REPLACE_ME
MFA_EMAIL_FROM=Tecnimotos <onboarding@resend.dev>
